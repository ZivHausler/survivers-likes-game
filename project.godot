; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Friends Swarm"
run/main_scene="res://game/session_root.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

GameEvents="*res://autoload/game_events.gd"
RunState="*res://autoload/run_state.gd"
Juice3D="*res://autoload/juice_3d.gd"
SkillVFX="*res://autoload/skill_vfx.gd"
VisualPalette="*res://core/visual_palette.gd"
Stylize="*res://vfx/stylize.gd"
NetworkManager="*res://net/network_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

